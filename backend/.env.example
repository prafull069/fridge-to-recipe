# Copy this file to .env and fill in your own values.

# Any OpenAI-compatible chat completions API works.
# Examples:
#   OpenAI:       BASE_URL=https://api.openai.com/v1        MODEL=gpt-4o-mini
#   Groq (free):  BASE_URL=https://api.groq.com/openai/v1   MODEL=llama-3.3-70b-versatile
#   OpenRouter:   BASE_URL=https://openrouter.ai/api/v1     MODEL=meta-llama/llama-3.1-8b-instruct:free
BASE_URL=https://api.groq.com/openai/v1
MODEL=llama-3.3-70b-versatile
API_KEY=your-api-key-here 
PORT=8787
